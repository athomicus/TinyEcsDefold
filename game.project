[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = ECS
dependencies#0 = https://github.com/ivanquirino/defold-tiny-ecs/archive/refs/tags/1.3-3.zip

[sprite]
max_count = 1024

